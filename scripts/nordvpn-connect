#!/usr/bin/env bash
# Usage: nordvpn-connect [hostname] [group]
HOSTNAME="${1:-}"
GROUP="${2:-}"

if [ "$GROUP" = "Obfuscated_Servers" ]; then
    echo "switching to openvpn"
    nordvpn set technology openvpn >/dev/null 2>&1
    nordvpn set obfuscate on >/dev/null 2>&1
fi

echo "spoofing mac"
sudo ip link set wlp1s0f0 down >/dev/null 2>&1
sudo macchanger -r wlp1s0f0 >/dev/null 2>&1
sudo ip link set wlp1s0f0 up >/dev/null 2>&1

echo "connecting"
ARGS=()
if [ -n "$HOSTNAME" ]; then SERVER="${HOSTNAME%.nordvpn.com}"; ARGS+=("$SERVER")
elif [ -n "$GROUP" ] && [ "$GROUP" != "Obfuscated_Servers" ]; then ARGS+=(-g "$GROUP"); fi

if nordvpn connect "${ARGS[@]}" >/dev/null 2>&1; then
    echo "done"
else
    if [ "$GROUP" = "Obfuscated_Servers" ]; then
        nordvpn set obfuscate off >/dev/null 2>&1
        nordvpn set technology nordlynx >/dev/null 2>&1
    fi
    echo "error:connect failed"
fi
